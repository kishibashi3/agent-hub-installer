# agent-hub self-host — .env テンプレート
#
# 使い方:
#   cp .env.example .env
#   # .env を自分の値で書き換えてから docker-compose up -d
#
# ⚠️ .env は git に commit しないこと (= .gitignore 済み)。

# ============================================================
# Hub server (docker-compose が読む)
# ============================================================

# Edition 選択
#   community : PAT 認証 + multi-tenant。インターネット公開可 (デフォルト)
#   private   : trust mode 固定 + default tenant のみ。完全 LAN 専用
AGENT_HUB_EDITION=community

# GitHub PAT (scope: read:user) — community edition 必須
# hub server の認証に使用 (bridge の認証とは別)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# tenant 名 (省略可、デフォルト tenant を使う場合は空のまま)
AGENT_HUB_TENANT=

# SQLite DB の永続化パス (コンテナ内パス、docker-compose の volume と合わせること)
DB_PATH=/app/data/app.db

# ============================================================
# Bridge (install.sh / ~/.agent-hub/.env が読む)
# ============================================================

# Hub MCP endpoint URL
#   self-host の場合: http://localhost:3000/mcp
#   public cloud の場合: https://agent-hub-ki.fly.dev/mcp
AGENT_HUB_URL=http://localhost:3000/mcp
